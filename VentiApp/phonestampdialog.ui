    font-weight: bold;
    color: #5d2d91;
    min-height: 50px; /* 버튼 높이를 키워 터치하기 좋게 만듦 */
}

/* 버튼이 눌렸을 때 (피드백) */
QPushButton:pressed {
    background-color: #5d2d91;
    color: white;
}</string>
       </property>
       <property name="text">
        <string>적립</string>
       </property>
      </widget>
     </item>
