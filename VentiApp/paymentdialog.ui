      <string notr="true">/* [위치: 상단 Grid Layout 내의 버튼들 또는 page_3 전체] */
QPushButton {
    background-color: #ffffff;
    border: 2px solid #5d2d91; /* 더벤티 보라색 테두리 */
    border-radius: 12px;
    padding: 8px;
    font-size: 13pt;
    font-weight: bold;
    color: #5d2d91;
    min-height: 50px; /* 버튼 높이를 키워 터치하기 좋게 만듦 */
}

/* 버튼이 눌렸을 때 (피드백) */
QPushButton:pressed {
    background-color: #5d2d91;
    color: white;
}</string>
