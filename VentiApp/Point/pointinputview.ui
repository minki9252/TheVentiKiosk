     <property name="styleSheet">
      <string notr="true">/* 전체 위젯의 강제 너비 제한 해제 */
QWidget#PointInputView, QWidget#PointResultView {
    background-color: #FFFFFF;
    min-width: 400px; /* 최소 너비만 보장 */
    max-width: 1000px; /* 최대치는 넉넉하게 설정하여 잘림 방지 */
}

/* 레이아웃 내부 요소들이 삐져나가지 않도록 패딩 조정 */
QVBoxLayout, QHBoxLayout {
    padding-right: 10px; /* 오른쪽 끝에 여백을 살짝 주어 잘림 현상 시각적 방지 */
}

/* 버튼들이 가로로 너무 꽉 차지 않게 설정 */
QPushButton {
    margin-right: 5px;
    margin-left: 5px;
}</string>
